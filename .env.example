# ── Copy this to .env and fill in your values ──────────────────────
# Never commit .env to git

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/agency_platform
MONGODB_DB_NAME=agency_platform

# AI APIs
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# Razorpay
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# Firebase (remote config + updates)
FIREBASE_CONFIG_URL=https://your-project.firebaseio.com/config.json
FIREBASE_UPDATE_URL=https://your-project.firebaseio.com/updates.json

# Server
PORT=8000
WORKERS=1
ENV=production
ALLOWED_ORIGINS=https://yourplatform.com,https://app.cusear.autos,https://cusear.autos

# Supabase (Web UI + local agent — Postgres + optional Auth)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Public URL of this API (used for WRA company_endpoint + agent instructions)
PUBLIC_API_BASE_URL=https://api.cusear.autos

# Dev: bypass Supabase for agent WebSocket + dashboard (same token string)
# CUSEAR_DEV_AGENT_TOKEN=dev-secret-token

# Manual QA signup (POST /api/cloud/v1/auth/signup) — use a long random secret in production
# CUSEAR_CLOUD_SIGNUP_SECRET=

# Resend (welcome email after subscription / manual signup)
# RESEND_API_KEY=re_...
# RESEND_FROM=cusear <onboarding@cusear.autos>
# PUBLIC_APP_URL=https://app.cusear.autos/app

# Rate limits
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=1000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
