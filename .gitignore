Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Test artifacts
.pytest_cache/
htmlcov/
.coverage

# Vercel build output (copied from portal/ on deploy)
/public/

# Production installers (copy into downloads/ on the server; keep manifest + README in git)
downloads/*.exe
downloads/*.dmg
downloads/*.msi
downloads/*.zip

