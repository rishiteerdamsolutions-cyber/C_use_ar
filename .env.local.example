# ═══════════════════════════════════════════════════════════════════════════
# Copy to .env.local and fill in YOUR values (never commit .env.local)
#   cp .env.local.example .env.local
#
# VERCEL (only if you deploy the FastAPI / platform API — not the desktop trainer):
#   Project → Settings → Environment Variables → add the same names.
#   The cusear™ app (python3 dashboard.py) does NOT run on Vercel.
#   Deploy uses vercel.json buildCommand: portal/ → public/ (static site); Python only for /api/*, /docs, /admin.
#   Do not add a vercel.json "functions"."api/index.py" block — it breaks validation; api/index.py is auto-detected.
# ═══════════════════════════════════════════════════════════════════════════

# ── MongoDB (required for agency_api/server.py — uvicorn) ────────────────────
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/agency_platform
MONGODB_DB_NAME=agency_platform

# ── AI APIs (API routes, vision, validator, trainer vision) ────────────────
OPENAI_API_KEY=sk-proj-replace-me
GEMINI_API_KEY=AIza-replace-me

# ── Trainer-only (local: python3 dashboard.py) ─────────────────────────────
# TRAINER_VISION_PROVIDER=openai
# TRAINER_OPENAI_VISION_MODEL=gpt-4o
# Optional only if you explicitly use Anthropic vision:
# ANTHROPIC_API_KEY=sk-ant-replace-me
# TRAINER_ANTHROPIC_VISION_MODEL=claude-3-5-sonnet-20241022
# TRAINER_LIVE_VISION_CLICKS=0
# TRAINER_LIVE_VISION_DELAY=0.35
# TRAINER_ACTIVATE_APP=Google Chrome
# macOS: brings that app to the front before each Click (and open_tab), not before Type — Type / type_project_name /
# AI Type paste into whatever already has keyboard focus. Set TRAINER_ACTIVATE_APP_BEFORE_TYPE=1 to restore activating
# before every Type step as well (old behavior).
# TRAINER_TYPE_FOCUS_DELAY=0
# Extra seconds before a Type step so the clicked field keeps focus (try 0.5–1.5 if paste lands elsewhere).
# TRAINER_NO_OPEN_BROWSER=0
# Workflow open_url (dashboard.py): macOS defaults to a new Chrome window (--new-window), which can feel like a
# “double load” before WhatsApp notify opens again. Set TRAINER_OPEN_URL_REUSE_CHROME_WINDOW=1 to reuse the window,
# or set per-step JSON on open_url: "reuse_chrome_window": true
# TRAINER_OPEN_URL_REUSE_CHROME_WINDOW=0
# Legacy automatic WhatsApp at end of each workflow run (dashboard.py _send_whatsapp_run_notification).
# Default is OFF — add completion_message / type_completion_message steps in each workflow instead.
# Set to 1 only if you still want Chrome + web.whatsapp.com/send after every run:
# TRAINER_WHATSAPP_NOTIFY=1
# If Dry run is on, workflow steps are simulated only — legacy notify still skips Chrome unless:
# TRAINER_WHATSAPP_NOTIFY_ON_DRY_RUN=1
# When TRAINER_WHATSAPP_NOTIFY=1: open Chrome + /send URL, then (after page load) wait TRAINER_WHATSAPP_STEP_WAIT_SEC
# (default 5s) after each sub-step: prefilled page ready → Tab×N → type mobile → Enter → wait → Enter (send). Chrome
# stays open by default; set TRAINER_WHATSAPP_QUIT_CHROME_AFTER_SEND=1 to quit after send.
# TRAINER_WHATSAPP_SKIP_REDUNDANT_OPEN=1       (skip step 1–2 if already on same /send URL)
# TRAINER_WHATSAPP_INTER_STEP_PAUSE_SEC=5     (extra pause after each major notify step: Chrome→URL, post-open phases)
# TRAINER_WHATSAPP_LAUNCH_GAP_SEC=1.2          (pause between launching Chrome and opening the URL; Darwin)
# TRAINER_WHATSAPP_ACTIVATE_CHROME=1           (bring Chrome to front before Tab/Enter)
# TRAINER_WHATSAPP_CHROME_ACTIVATE_DELAY=0.7   (macOS: post-activate delay)
# TRAINER_WHATSAPP_PAGE_LOAD_WAIT_SEC=2        (settle time after opening WhatsApp URL, before the first 5s step gap)
# TRAINER_WHATSAPP_REFOCUS_AFTER_PAGE_LOAD=1  (1 = bring Chrome back after page settle — WhatsApp refresh can drop focus)
# TRAINER_WHATSAPP_REFOCUS_BEFORE_TAB=1      (1 = again before Tab×N / key sequence)
# TRAINER_WHATSAPP_REFOCUS_SETTLE_SEC=0.5    (pause after each refocus; helps keys land in WhatsApp)
# TRAINER_WHATSAPP_MAXIMIZE_BEFORE_KEYS=1     (1 = same as workflow maximize: macOS Ctrl+Cmd+F, Windows Win+Up, then short settle)
# TRAINER_WHATSAPP_MAXIMIZE_SETTLE_SEC=0.45  (pause after maximize before Tab/Enter)
# TRAINER_WHATSAPP_STEP_WAIT_SEC=5            (seconds between each major post-open step; used by PyAutoGUI + System Events)
# On macOS, the notify key sequence uses AppleScript/System Events by default (more reliable than PyAutoGUI when WA refreshes):
# TRAINER_WHATSAPP_DARWIN_APPLESCRIPT_KEYS=1   (set 0 to drive keys with PyAutoGUI instead)
# TRAINER_WHATSAPP_OSASCRIPT_CHROME_ACTIVATE_SEC=0.55  (activate Chrome before key script in the AppleScript path)
# TRAINER_WHATSAPP_TAB_COUNT=4                (Tab presses before typing the notify mobile)
# (Legacy, ignored by the current notify post-open sequence — use TRAINER_WHATSAPP_STEP_WAIT_SEC instead)
# # TRAINER_WHATSAPP_WAIT_AFTER_PAGE_SEC=5
# # TRAINER_WHATSAPP_WAIT_BETWEEN_ENTERS_SEC=5
# TRAINER_WHATSAPP_WAIT_BEFORE_CLOSE_SEC=1   (only when TRAINER_WHATSAPP_QUIT_CHROME_AFTER_SEND=1: pause before quit)
# TRAINER_WHATSAPP_PRESS_ENTER_AFTER_OPEN=1   (set 0 to skip keyboard + close block)
# TRAINER_WHATSAPP_POST_OPEN_SEQUENCE=1       (set 0 to skip)
# TRAINER_WHATSAPP_POST_OPEN_KEY_SEQUENCE=0  (set 1 to re-enable Tab+retype phone+Enter after /send; default 0
#   keeps prefilled text — the old key sequence often cleared the compose field on web.whatsapp.com)
# TRAINER_WHATSAPP_QUIT_CHROME_AFTER_SEND=0   (set 1 to quit Chrome after send; default 0 = leave open)
# TRAINER_WHATSAPP_OPEN_BLANK_TAB_AFTER_SEND=0  (only if QUIT=0 and you want a blank tab)
# Prefilled completion text: default is one short line; set 1 for the older long message (source, mode, platforms, …)
# TRAINER_WHATSAPP_COMPLETION_VERBOSE=0
# TRAINER_WHATSAPP_URL_TEXT_MAX_CHARS=2000

# Scheduler (auto-run workflows in background)
# Desktop / main.py --trainer: default is OFF unless you set TRAINER_SCHEDULER_ENABLED=1 (avoids surprise runs while testing).
# python dashboard.py / START.sh: default is ON unless TRAINER_SCHEDULER_ENABLED=0
# TRAINER_SCHEDULER_ENABLED=1
# TRAINER_SCHEDULER_CATCH_UP_MISSED_RUNS=0  (default 0: if tool was closed and a schedule was missed, DO NOT run it on reopen)

# ── Full website agent (build + deploy + DB + admin UI) ─────────────────────
# You still must respect each vendor’s Terms of Service, quotas, and auth. There is no way to
# “remove restrictions” on ChatGPT, Google, Meta, etc.; use official APIs/CLIs and your own keys.
# Suggested pipeline (trainer workflows + main.py templates):
#   1) cursor /path/to/app          — open project in Cursor (human or agent edits; paste prompt)
#   2) npm run build / vercel …     — ship frontend + API routes
#   3) gh … / git push              — source control
#   4) firebase deploy / gcloud …   — hosting or backend services
#   5) mongosh / atlas …            — data layer; MONGODB_URI in deployed env
# ChatGPT: use OPENAI_API_KEY in app code or openai CLI (pip install openai[cli]); no stable “ChatGPT web” CLI.
# Google Cloud “console”: use gcloud / gsutil + APIs. Search Console / Play often need HTTP APIs, not one CLI.

# Shell steps (trainer “🔧 Shell” — CLIs instead of fragile browser clicks)
# TRAINER_ALLOW_SHELL=1
# TRAINER_SHELL_UNRESTRICTED=0
# Set to 1 only on a trusted dev machine — disables allowlist so ANY command name in a shell step can run.
# Default allowlist if unset (first word of each command):
#   git,gh,cursor,openai,npm,pnpm,yarn,node,vercel,firebase,gcloud,gsutil,mongosh,mongo,atlas
# TRAINER_SHELL_ALLOWLIST=git,gh,cursor,openai,npm,pnpm,yarn,node,vercel,firebase,gcloud,gsutil,mongosh,mongo,atlas
# TRAINER_SHELL_TIMEOUT=180
# Working directory for shell steps (git/vercel/npm run here). Repo includes agent-builds/staging/ for this:
# TRAINER_SHELL_CWD=/absolute/path/to/autonomous-web-agency/agent-builds/staging

# ── Desktop agent (main.py / WorkflowRunner — execution/executor.py) ───────
# Typing uses clipboard paste by default (exact newlines & Unicode). Uncomment to force keystrokes:
# EXECUTOR_TYPE_USE_KEYSTROKES=1

# ── Razorpay (billing — legacy; optional if you only use Cashfree) ───────
RAZORPAY_KEY_ID=rzp_live_replace_me
RAZORPAY_KEY_SECRET=replace_me
RAZORPAY_WEBHOOK_SECRET=replace_me

# ── Cashfree (PG — India; preferred for new go-to-market) ───────────────────
# Dashboard: https://merchant.cashfree.com — create an app, enable Payment Gateway, set webhook URL.
# Server: create order/session → return session_id to frontend → Cashfree JS / redirect → verify webhook.
CASHFREE_APP_ID=replace_me
CASHFREE_SECRET_KEY=replace_me
CASHFREE_CLIENT_ID=replace_me_if_using_oauth_flow
# Webhook: verify x-cf-signature with secret below (see Cashfree docs for your API version)
CASHFREE_WEBHOOK_SECRET=replace_me
# test | prod
CASHFREE_API_ENV=prod

# ── Firebase (optional remote config / updates) ────────────────────────────
FIREBASE_CONFIG_URL=https://your-project.firebaseio.com/config.json
FIREBASE_UPDATE_URL=https://your-project.firebaseio.com/updates.json

# ── API server ───────────────────────────────────────────────────────────────
PORT=8000
WORKERS=2
ENV=production
ALLOWED_ORIGINS=https://your-app.vercel.app,https://yourplatform.com

# ── Cloud trainer (FastAPI /api/trainer — MongoDB workflows) ─────────────────
# TRAINER_REQUIRE_API_KEY=0
# Set to 1 so only requests with X-API-Key can use the trainer; each key’s workflows are isolated (required for selling per-client).

# ── Rate limits / Redis (optional; use Upstash URL on Vercel if needed) ─────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=1000
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Whitelabel / platform ──────────────────────────────────────────────────
# On Vercel, PLATFORM_DOMAIN defaults from VERCEL_URL (e.g. cuseai.vercel.app) so tenant subdomains work.
PLATFORM_DOMAIN=yourplatform.com
PLATFORM_ADMIN_TOKEN=generate-a-long-random-string
API_ENV=live

# ── Email (onboarding / notifications) ─────────────────────────────────────
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=app-specific-password

# ── Agent / main.py extras (optional) ──────────────────────────────────────
# APP_MODE=development
# NEXT_PUBLIC_WHATSAPP_NUMBER=
# WORKFLOW_MASTER_KEY=
# LICENSE_MASTER_SECRET=

# ── Entitlements & pricing (API + local trainer when enforcement enabled) ───
# ENTITLEMENTS_ENFORCEMENT=0          # 1 = enforce module + AI quota on runs
# ENTITLED_MODULES=instagram_ar,linkedin_ar   # CSV when enforcement on (local trainer / desktop)
# TRAINER_AI_RUNS_MONTHLY_CAP=0       # max AI-attributed runs per calendar month locally; 0 = unlimited
# Mongo api_keys may include: entitled_modules (list), ai_runs_monthly_quota (int, 0=unlimited)

# Variable cost model for margin checks (POST /api/v1/billing/validate-plan-margin)
# VARIABLE_COST_AI_RUN_INR=15
# PLAN_EXPECTED_AI_RUNS_MONTH=600
# PAYMENT_FEE_PERCENT=2.5
# PAYMENT_FEE_FIXED_INR_PER_RUN=0
# INFRA_SHARE_INR_PER_RUN=0.5
# MIN_GROSS_MARGIN_FLOOR=0.90
# MARGIN_WARN_BELOW=0.93

# FX: INR per 1 USD (fallback if Mongo platform_settings doc missing)
# PLATFORM_FX_INR_PER_USD=83

# Desktop: require license.key before UI. PyInstaller build defaults ON; source `python desktop.py` defaults OFF.
# DESKTOP_LICENSE_CHECK=1

# ── Testing council (Round 2/3 API judges) — avoid free-tier TPM / rate-limit stalls ──
# TESTING_COUNCIL_API_PROVIDER=groq
# TESTING_COUNCIL_JUDGE_DELAY_SEC=15          # pause between each Round 2 judge call (0 = off)
# TESTING_COUNCIL_API_RETRIES=6               # retries on 429 / 413 / rate_limit style errors
# TESTING_COUNCIL_RETRY_BASE_DELAY_SEC=12     # base backoff; grows per attempt
# TESTING_COUNCIL_MAX_OUTPUT_TOKENS=1024      # max completion tokens (unset: 1024 groq, 2048 gemini, 4096 openai)
# TESTING_COUNCIL_MAX_ANSWER_CHARS=500        # trim Round 1 text sent to judges
# TESTING_COUNCIL_MAX_JUDGEMENT_CHARS=700     # trim Round 2 text sent to final judge
# Point at a local OpenAI-compatible server (e.g. Ollama: ollama serve → http://127.0.0.1:11434/v1 )
# TESTING_COUNCIL_API_PROVIDER=openai
# TESTING_COUNCIL_OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# TESTING_COUNCIL_OPENAI_API_KEY=ollama   # local key; keeps OPENAI_API_KEY for trainer vision / OpenAI cloud
# OPENAI_API_KEY=sk-proj-...              # still used for TRAINER_VISION_PROVIDER=openai when not using Ollama for judges
# Round 1 stays browser automation; Round 2 = five API calls with the same anonymous Answer 1–5 bundle.
# Use one Ollama model for all five judges (personas differ per slot by default); Round 3 can use another tag, e.g. Gemma:
# TESTING_COUNCIL_ROUND2_MODEL=llama3.2
# TESTING_COUNCIL_ROUND3_MODEL=gemma2
# Optional per-slot model overrides (usually leave unset so all five use ROUND2_MODEL):
# # TESTING_COUNCIL_ROUND2_CHATGPT_MODEL=llama3.2
# # TESTING_COUNCIL_ROUND2_GEMINI_MODEL=llama3.2
# # …
# TESTING_COUNCIL_JUDGE_PROMPT_STYLE=extractive   # default: preserve signal, structured Round 2, meta Round 3
# TESTING_COUNCIL_JUDGE_PROMPT_STYLE=classic      # short legacy judge prompts; Round 2 personas apply if enabled
