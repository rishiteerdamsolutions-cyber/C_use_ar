# ═══════════════════════════════════════════════════════════════════════════
# Copy to .env.local and fill in YOUR values (never commit .env.local)
#   cp .env.local.example .env.local
#
# VERCEL (only if you deploy the FastAPI / platform API — not the desktop trainer):
#   Project → Settings → Environment Variables → add the same names.
#   The Web Agency Trainer (python3 dashboard.py) does NOT run on Vercel.
# ═══════════════════════════════════════════════════════════════════════════

# ── MongoDB (required for agency_api/server.py — uvicorn) ────────────────────
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/agency_platform
MONGODB_DB_NAME=agency_platform

# ── AI APIs (API routes, vision, validator, trainer vision) ────────────────
OPENAI_API_KEY=sk-proj-replace-me
ANTHROPIC_API_KEY=sk-ant-replace-me
GEMINI_API_KEY=AIza-replace-me

# ── Trainer-only (local: python3 dashboard.py) ─────────────────────────────
# TRAINER_VISION_PROVIDER=auto
# TRAINER_OPENAI_VISION_MODEL=gpt-4o
# TRAINER_ANTHROPIC_VISION_MODEL=claude-3-5-sonnet-20241022
# TRAINER_LIVE_VISION_CLICKS=0
# TRAINER_LIVE_VISION_DELAY=0.35
# TRAINER_ACTIVATE_APP=Google Chrome
# Brings that app to the front before each Type and Click (macOS) so automation hits Chrome, not Cursor’s terminal.
# TRAINER_TYPE_FOCUS_DELAY=0
# Extra seconds before a Type step so the clicked field keeps focus (try 0.5–1.5 if paste lands elsewhere).
# TRAINER_NO_OPEN_BROWSER=0

# ── Full website agent (build + deploy + DB + admin UI) ─────────────────────
# You still must respect each vendor’s Terms of Service, quotas, and auth. There is no way to
# “remove restrictions” on ChatGPT, Google, Meta, etc.; use official APIs/CLIs and your own keys.
# Suggested pipeline (trainer workflows + main.py templates):
#   1) cursor /path/to/app          — open project in Cursor (human or agent edits; paste prompt)
#   2) npm run build / vercel …     — ship frontend + API routes
#   3) gh … / git push              — source control
#   4) firebase deploy / gcloud …   — hosting or backend services
#   5) mongosh / atlas …            — data layer; MONGODB_URI in deployed env
# ChatGPT: use OPENAI_API_KEY in app code or openai CLI (pip install openai[cli]); no stable “ChatGPT web” CLI.
# Google Cloud “console”: use gcloud / gsutil + APIs. Search Console / Play often need HTTP APIs, not one CLI.

# Shell steps (trainer “🔧 Shell” — CLIs instead of fragile browser clicks)
# TRAINER_ALLOW_SHELL=1
# TRAINER_SHELL_UNRESTRICTED=0
# Set to 1 only on a trusted dev machine — disables allowlist so ANY command name in a shell step can run.
# Default allowlist if unset (first word of each command):
#   git,gh,cursor,openai,npm,pnpm,yarn,node,vercel,firebase,gcloud,gsutil,mongosh,mongo,atlas
# TRAINER_SHELL_ALLOWLIST=git,gh,cursor,openai,npm,pnpm,yarn,node,vercel,firebase,gcloud,gsutil,mongosh,mongo,atlas
# TRAINER_SHELL_TIMEOUT=180
# Working directory for shell steps (git/vercel/npm run here). Repo includes agent-builds/staging/ for this:
# TRAINER_SHELL_CWD=/absolute/path/to/autonomous-web-agency/agent-builds/staging

# ── Desktop agent (main.py / WorkflowRunner — execution/executor.py) ───────
# Typing uses clipboard paste by default (exact newlines & Unicode). Uncomment to force keystrokes:
# EXECUTOR_TYPE_USE_KEYSTROKES=1

# ── Razorpay (billing) ─────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_replace_me
RAZORPAY_KEY_SECRET=replace_me
RAZORPAY_WEBHOOK_SECRET=replace_me

# ── Firebase (optional remote config / updates) ────────────────────────────
FIREBASE_CONFIG_URL=https://your-project.firebaseio.com/config.json
FIREBASE_UPDATE_URL=https://your-project.firebaseio.com/updates.json

# ── API server ───────────────────────────────────────────────────────────────
PORT=8000
WORKERS=2
ENV=production
ALLOWED_ORIGINS=https://your-app.vercel.app,https://yourplatform.com

# ── Cloud trainer (FastAPI /api/trainer — MongoDB workflows) ─────────────────
# TRAINER_REQUIRE_API_KEY=0
# Set to 1 so only requests with X-API-Key can use the trainer; each key’s workflows are isolated (required for selling per-client).

# ── Rate limits / Redis (optional; use Upstash URL on Vercel if needed) ─────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=1000
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Whitelabel / platform ──────────────────────────────────────────────────
# On Vercel, PLATFORM_DOMAIN defaults from VERCEL_URL (e.g. cuseai.vercel.app) so tenant subdomains work.
PLATFORM_DOMAIN=yourplatform.com
PLATFORM_ADMIN_TOKEN=generate-a-long-random-string
API_ENV=live

# ── Email (onboarding / notifications) ─────────────────────────────────────
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=app-specific-password

# ── Agent / main.py extras (optional) ──────────────────────────────────────
# APP_MODE=development
# NEXT_PUBLIC_WHATSAPP_NUMBER=
# WORKFLOW_MASTER_KEY=
# LICENSE_MASTER_SECRET=
