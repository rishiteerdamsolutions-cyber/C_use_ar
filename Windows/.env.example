# ── Copy this to .env and fill in your values ──────────────────────
# Never commit .env to git

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/agency_platform
MONGODB_DB_NAME=agency_platform

# AI APIs
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# Razorpay
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# Firebase (remote config + updates)
FIREBASE_CONFIG_URL=https://your-project.firebaseio.com/config.json
FIREBASE_UPDATE_URL=https://your-project.firebaseio.com/updates.json

# Server
PORT=8000
WORKERS=2
ENV=production
ALLOWED_ORIGINS=https://yourplatform.com

# Rate limits
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=1000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
